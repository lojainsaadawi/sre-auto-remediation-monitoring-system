            "content": "# Ansible Inventory — Auto-generated by Terraform\n# Do not edit manually — regenerated on every terraform apply\n\n[controller]\ncontroller ansible_host=192.168.122.55 ansible_user=root\n\n[edge_nodes]\nedge-node-1 ansible_host=10.0.10.153 ansible_user=ubuntu zone=zone1 vm_id=6e6147b2-cb97-4436-a0b8-0f4c76daac4d private_ip=10.2.1.27\nedge-node-2 ansible_host=10.0.10.187 ansible_user=ubuntu zone=zone2 vm_id=a30f7f11-64d6-4788-a04c-830b50f3bebc private_ip=10.2.2.47\n\n[standby]\nedge-node-3 ansible_host=10.0.10.160 ansible_user=ubuntu zone=standby vm_id=73da3891-c18e-4dc7-bdff-ab0c22206b3a private_ip=10.2.2.13\n\n[all_vms:children]\nedge_nodes\nstandby\n\n[all:vars]\nansible_ssh_private_key_file = ~/.ssh/edge-key.pem\nansible_python_interpreter   = /usr/bin/python3\nansible_ssh_common_args      = '-o ProxyCommand=\"ssh -W %h:%p -q root@192.168.122.55 -o StrictHostKeyChecking=no\" -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'\nmqtt_broker                  = 192.168.122.1\nmqtt_port                    = 1883\nproxy_http                   = http://10.0.10.11:3128\n",
